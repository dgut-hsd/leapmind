# ==========================================
# EditorConfig - 跨编辑器代码格式统一
# VS Code / IntelliJ / WebStorm 均自动生效
# ==========================================
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Java
[*.java]
indent_style = space
indent_size = 4

# Python
[*.py]
indent_style = space
indent_size = 4

# JavaScript / TypeScript / JSX / TSX
[*.{js,jsx,ts,tsx}]
indent_style = space
indent_size = 2

# YAML
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# JSON
[*.json]
indent_style = space
indent_size = 2

# Markdown
[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

# XML
[*.xml]
indent_style = space
indent_size = 4
