{
  "openapi": "3.1.0",
  "info": {
    "title": "LeapMind AI Service",
    "description": "AI微服务 - 提供OCR后处理、AI答疑、AI讲题等能力",
    "version": "0.1.0"
  },
  "paths": {
    "/api/internal/ai/ocr/process": {
      "post": {
        "tags": [
          "LeapMind - OCR"
        ],
        "summary": "Process Ocr",
        "operationId": "process_ocr_api_internal_ai_ocr_process_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OCRProcessRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OCRProcessResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/internal/ai/generate": {
      "post": {
        "tags": [
          "LeapMind - AI Generate"
        ],
        "summary": "Generate",
        "description": "Non-streaming AI generation",
        "operationId": "generate_api_internal_ai_generate_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AIGenerateRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/internal/ai/generate/stream": {
      "post": {
        "tags": [
          "LeapMind - AI Generate"
        ],
        "summary": "Generate Stream",
        "description": "SSE streaming AI generation",
        "operationId": "generate_stream_api_internal_ai_generate_stream_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AIGenerateRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "summary": "Health Check",
        "operationId": "health_check_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/": {
      "get": {
        "summary": "Root",
        "operationId": "root__get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AIGenerateRequest": {
        "properties": {
          "module": {
            "type": "string",
            "title": "Module"
          },
          "scene": {
            "type": "string",
            "title": "Scene"
          },
          "params": {
            "additionalProperties": true,
            "type": "object",
            "title": "Params",
            "default": {}
          },
          "prompt": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Prompt"
          },
          "modelName": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Modelname"
          },
          "maxTokens": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Maxtokens"
          },
          "temperature": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Temperature"
          }
        },
        "type": "object",
        "required": [
          "module",
          "scene"
        ],
        "title": "AIGenerateRequest"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "OCRProcessRequest": {
        "properties": {
          "rawText": {
            "type": "string",
            "title": "Rawtext"
          },
          "subject": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Subject"
          },
          "imageUrl": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Imageurl"
          }
        },
        "type": "object",
        "required": [
          "rawText"
        ],
        "title": "OCRProcessRequest"
      },
      "OCRProcessResponse": {
        "properties": {
          "recognizedText": {
            "type": "string",
            "title": "Recognizedtext"
          },
          "structuredQuestion": {
            "$ref": "#/components/schemas/StructuredQuestion"
          },
          "confidence": {
            "type": "number",
            "title": "Confidence"
          }
        },
        "type": "object",
        "required": [
          "recognizedText",
          "structuredQuestion",
          "confidence"
        ],
        "title": "OCRProcessResponse"
      },
      "QuestionType": {
        "type": "string",
        "enum": [
          "single_choice",
          "multi_choice",
          "fill_blank",
          "short_answer",
          "essay"
        ],
        "title": "QuestionType"
      },
      "StructuredQuestion": {
        "properties": {
          "stem": {
            "type": "string",
            "title": "Stem"
          },
          "options": {
            "anyOf": [
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Options"
          },
          "type": {
            "$ref": "#/components/schemas/QuestionType"
          },
          "subject": {
            "type": "string",
            "title": "Subject"
          }
        },
        "type": "object",
        "required": [
          "stem",
          "type",
          "subject"
        ],
        "title": "StructuredQuestion"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}